generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  authId         String   @unique
  email          String   @unique
  name           String
  birthDate DateTime?
  biologicalSex  String
  romanticTarget String
  height         Int?
  weight         Int?
  hobbies        String?
  occupation     String?
  livingArea     String?
  meetingArea    String?
  bio            String?
  imageUrls      String[]
  createdAt      DateTime @default(now())

  sentLikes      Like[]    @relation("sentLikes")
  receivedLikes  Like[]    @relation("receivedLikes")
  matchesAsUser1 Match[]   @relation("MatchUser1")
  matchesAsUser2 Match[]   @relation("MatchUser2")
  messages       Message[] @relation("MessageSender")
}

model Like {
  id         String   @id @default(cuid())
  fromUserId String
  toUserId   String
  createdAt  DateTime @default(now())

  fromUser User @relation("sentLikes", fields: [fromUserId], references: [id])
  toUser   User @relation("receivedLikes", fields: [toUserId], references: [id])
}

model Swipe {
  id         String   @id @default(cuid())
  fromUserId String
  toUserId   String
  action     String
  createdAt  DateTime @default(now())

  @@unique([fromUserId, toUserId])
}

model Match {
  id        String   @id @default(cuid())
  user1Id   String
  user2Id   String
  createdAt DateTime @default(now())

  user1WantsMeet Boolean   @default(false)
  user2WantsMeet Boolean   @default(false)
  meetMatchedAt  DateTime?

  user1 User @relation("MatchUser1", fields: [user1Id], references: [id])
  user2 User @relation("MatchUser2", fields: [user2Id], references: [id])

  messages Message[]
}

model Message {
  id        String   @id @default(cuid())
  matchId   String
  senderId  String
  text      String
  createdAt DateTime @default(now())

  match  Match @relation(fields: [matchId], references: [id])
  sender User  @relation("MessageSender", fields: [senderId], references: [id])
}

